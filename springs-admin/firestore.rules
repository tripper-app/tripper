rules_version = '2';

// Reference rules for the Tripper springs admin.
// Goal: the mobile app keeps working (its Cloud Functions use the Admin SDK,
// which BYPASSES these rules), while the admin web app — signed in with Firebase
// Auth — can read and write the `springs` collection directly from the browser.
//
// Apply in Firebase Console → Firestore Database → Rules (merge with any existing
// rules; do not blindly overwrite rules the mobile client depends on).
service cloud.firestore {
  match /databases/{database}/documents {
    // Only signed-in admins may read/write springs from the client.
    match /springs/{springId} {
      allow read, write: if request.auth != null;
    }

    // Everything else stays closed to direct client access (the app's Cloud
    // Functions use the Admin SDK and are unaffected by these rules).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
